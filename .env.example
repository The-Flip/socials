# Copy to .env and fill in. Never commit real credentials.
# Secrets are read from the environment — see docs/plans/Product.md for the roadmap.

# Instagram (first connected platform — reporting is read-only)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_ACCOUNT_ID=

# Discord (report delivery — later milestone)
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# Buffer (data source for `socials report`) — read-only Public API (GraphQL) token.
# Create one at https://buffer.com/developers ; it may need periodic re-authorization.
BUFFER_API_KEY=
